{
  "schemaVersion": 1,
  "id": "hqtiers",
  "version": "${version}",
  "name": "HQTiers",
  "description": "Unofficial Tier Tagger built by a member of the server's staff team",
  "authors": [
    "micahcode"
  ],
  "contact": {
    "homepage": "https://pvphq.com/",
    "issues": "https://github.com/MicahXX/hqtiers/issues"
  },
  "license": "MIT",
  "icon": "assets/hqtiers/icon.png",
  "environment": "*",

  "entrypoints": {
    "modmenu": [
      "me.micahcode.hqtiers.client.config.HqTiersModMenu"
    ],
    "client": [
      "me.micahcode.hqtiers.client.HqTiersClient"
    ],
    "main": [
      "me.micahcode.hqtiers.Hqtiers"
    ]
  },

  "mixins": [
    {
      "config": "hqtiers.client.mixins.json",
      "environment": "client"
    }
  ],

  "depends": {
    "fabricloader": ">=0.17.2",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "cloth-config": "*",
    "modmenu": "*"
  },

  "custom": {
    "modmenu": {
      "links": {
        "modmenu.discord": "https://discord.gg/pvphq"
      },
      "badges": [
        "Tier Tagger"
      ],
      "update_checker": true
    }
  }
}